# Auth.js — gere com: openssl rand -base64 32
AUTH_SECRET=

# Turso (libSQL) — na Vercel a integração pode usar BLOB_TURSO_* (o código aceita ambos)
TURSO_CONNECTION_URL=
TURSO_AUTH_TOKEN=
BLOB_TURSO_DATABASE_URL=
BLOB_TURSO_AUTH_TOKEN=

# Google Gemini (server-side)
GEMINI_API_KEY=

# tldraw — produção: https://tldraw.dev/get-a-license/trial
NEXT_PUBLIC_TLDRAW_LICENSE_KEY=

# Vercel Blob — persistência do canvas (server-only)
BLOB_READ_WRITE_TOKEN=
